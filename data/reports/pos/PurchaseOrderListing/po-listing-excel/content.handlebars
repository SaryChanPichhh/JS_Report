<html>
  <head>
    <meta charset="utf-8" />

    <style>
      {{asset "data/reports/assets/report.css"}}
    </style>
  </head>

  <body class="bg-white text-slate-900 text-[11px]">
    <div class="w-full">

      <!-- Header -->
      <div
        class="flex items-start justify-between border-b-2 border-primary pb-4"
      >
        <div>
          <h1 class="text-2xl font-bold text-primary">Purchase Order Listing</h1>
          <p class="mt-1 text-slate-500">Grouped by Receive Date and Transaction
            Reference</p>
        </div>

        <div class="text-right">
          <p class="text-lg font-bold text-primary">Tonaire Digital</p>
          <p class="text-xs text-slate-500">Generated by jsreport</p>
        </div>
      </div>

      <!-- Filter -->
      <div class="mt-4 grid grid-cols-3 gap-3 rounded-lg bg-primary-soft p-3">
        <div>
          <p class="text-xs text-slate-500">Start Date</p>
          <p class="font-semibold">{{formatDate StartDate}}</p>
        </div>

        <div>
          <p class="text-xs text-slate-500">End Date</p>
          <p class="font-semibold">{{formatDate EndDate}}</p>
        </div>

        <div>
          <p class="text-xs text-slate-500">Language</p>
          <p class="font-semibold">{{Language}}</p>
        </div>
      </div>

      <!-- Group 1: ReceiveDate -->
      {{#each Orders}}
        <div class="mt-6">

          <div class="rounded-t-lg bg-primary px-4 py-2 text-white">
            <h2 class="text-sm font-bold">
              Receive Date:
              {{formatDate ReceiveDate}}
            </h2>
          </div>

          <!-- Group 2: TransRef -->
          {{#each (groupByTransRef Items)}}
            <div class="border border-slate-300 border-t-0">

              <!-- TransRef Header -->
              <div class="bg-slate-100 px-4 py-2">
                <div class="flex justify-between">
                  <div>
                    <span class="font-bold text-primary">Trans Ref:</span>
                    <span class="font-semibold">{{TransRef}}</span>
                  </div>

                  <div>
                    <span class="font-bold text-primary">Supplier:</span>
                    <span>{{SupplierName}}</span>
                    <span class="text-slate-500">({{SupplierCode}})</span>
                  </div>

                  <div>
                    <span class="font-bold text-primary">Warehouse:</span>
                    <span>{{Warehouse}}</span>
                  </div>
                </div>
              </div>

              <!-- Items Table -->
              <table class="w-full border-collapse text-[10px]">
                <thead>
                  <tr class="bg-primary text-white">
                    <th class="border border-primary p-2 text-left">Time</th>
                    <th class="border border-primary p-2 text-left">Item Code</th>
                    <th class="border border-primary p-2 text-left">Item
                      Description</th>
                    <th class="border border-primary p-2 text-right">Qty</th>
                    <th class="border border-primary p-2 text-right">Cost</th>
                    <th class="border border-primary p-2 text-right">Total Cost</th>
                    <th class="border border-primary p-2 text-right">Exchange
                      Rate</th>
                  </tr>
                </thead>

                <tbody>
                  {{#each Items}}
                    <tr>
                      <td class="border border-slate-300 p-2">{{Time}}</td>
                      <td class="border border-slate-300 p-2">{{ItemCode}}</td>
                      <td class="border border-slate-300 p-2">
                        {{itemDescription this @root.Language}}
                      </td>
                      <td
                        class="border border-slate-300 p-2 text-right"
                      >{{Qty}}</td>
                      <td
                        class="border border-slate-300 p-2 text-right"
                      >{{formatMoney Cost}}</td>
                      <td
                        class="border border-slate-300 p-2 text-right font-semibold"
                      >{{formatMoney TotalCost}}</td>
                      <td
                        class="border border-slate-300 p-2 text-right"
                      >{{formatMoney ExchangeRate}}</td>
                    </tr>
                  {{/each}}
                </tbody>

                <tfoot>
                  <tr class="bg-primary-soft font-bold">
                    <td
                      class="border border-slate-300 p-2 text-right"
                      colspan="3"
                    >
                      TransRef Total
                    </td>
                    <td
                      class="border border-slate-300 p-2 text-right"
                    >{{TotalQty}}</td>
                    <td class="border border-slate-300 p-2"></td>
                    <td
                      class="border border-slate-300 p-2 text-right"
                    >{{formatMoney TotalCost}}</td>
                    <td class="border border-slate-300 p-2"></td>
                  </tr>
                </tfoot>
              </table>
            </div>
          {{/each}}
        </div>
      {{/each}}

    </div>
  </body>
</html>