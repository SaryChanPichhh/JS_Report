<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inventory Status Report</title>
    <style>
      {{asset "data/reports/assets/report.css"}}
    </style>
  </head>
  <body class="bg-white text-slate-900 p-2">
    <div class="w-full">

      <!-- Header Section -->
      <div
        class="flex justify-between items-start border-b-2 border-primary pb-2 mb-2"
      >
        <div class="flex items-center gap-4">
          {{#if shopImage}}
            <div
              class="w-16 h-16 rounded-lg border border-slate-300 bg-slate-100 p-1 flex items-center justify-center"
            >
              <img
                class="max-w-full max-h-full object-contain"
                src="{{shopImage}}"
                alt="{{shopName}} Logo"
                onerror="this.style.display='none';"
              />
            </div>
          {{/if}}
          <div class="flex flex-col">
            <h1
              class="text-lg font-bold text-slate-900 leading-tight"
            >{{shopName}}</h1>
            <p class="text-[11px] text-gray-500 mt-0.5">Inventory Valuation &
              Stock Status</p>
          </div>
        </div>

        <div class="text-right">
          <h2
            class="text-xl font-bold text-primary mb-1 tracking-wider"
          >INVENTORY REPORT</h2>
          <div class="grid grid-cols-2 gap-1 text-[11px] text-gray-700">
            <span class="text-right font-semibold">Print Date:</span>
            <span class="text-left">{{formatDate printDate}}</span>

          </div>
        </div>
      </div>

      <!-- Summary Metrics Cards (2x2 Grid) -->

      <!-- Inventory Details Table -->
      <table class="w-full border-collapse table-fixed">
        <colgroup>
          <col style="width: 8%;" />
          <col style="width: 20%;" />
          <!-- Code -->
          <col style="width: 32%;" />
          <!-- Description -->
          <col style="width: 10%;" />
          <!-- Stock -->
          <col style="width: 13%;" />
          <!-- Cost Price (USD) -->
          <col style="width: 15%;" />
          <!-- Total Cost (USD) -->
        </colgroup>
        <thead>
          <tr class="bg-gray-100 border-b-2 border-gray-300">
            <th
              class="text-left font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >No.</th>
            <th
              class="text-left font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Code</th>
            <th
              class="text-left font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Description</th>
            <th
              class="text-center font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Stock</th>
            <th
              class="text-right font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Unit Cost</th>
            <th
              class="text-right font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Total (USD)</th>
        </thead>
        <tbody>
          {{#each (groupByCategory items)}}
            <!-- Category Header Row -->
            <tr class="bg-primary text-white border-b border-primary">
              <td
                colspan="3"
                class="p-2 font-bold text-[11px] uppercase tracking-wider"
              >
                Category:
                {{category}}
              </td>
              <td
                class="p-2 text-center font-bold text-[12px]"
              >{{subTotalStock}}</td>
              <td class="p-2 text-right"></td>
              <td class="p-2 text-right font-bold text-[12px]">{{formatUSD
                  subTotalCostUSD
                }}</td>
            </tr>

            <!-- Category Items Row -->
            {{#each items}}
              <tr class="border-b border-gray-200 even:bg-gray-50">
                   <td
                  class="p-2 text-[11px] font-mono text-gray-600"
                >{{rowNumber @index}}</td>
                <td
                  class="p-2 text-[11px] font-mono text-gray-600"
                >{{itemCode}}</td>
                <td
                  class="p-2 text-[11px] font-medium text-slate-900"
                >{{itemDesc}}</td>
                <td
                  class="p-2 text-[11px] text-center text-slate-900"
                >{{stock}}</td>
                <td
                  class="p-2 text-[11px] text-right text-slate-900"
                >{{formatUSD costPrice}}</td>
                <td
                  class="p-2 text-[11px] text-right font-semibold text-slate-900"
                >{{formatUSD (lineTotalUSD stock costPrice)}}</td>
              </tr>
            {{/each}}
          {{/each}}

          <!-- Grand Total Row -->
          <tr
            class="bg-gray-100 border-t-2 border-b-2 border-primary font-bold"
          >
            <td
              colspan="3"
              class="p-2 text-[12px] text-slate-900 text-left uppercase"
            >GRAND TOTAL</td>
            <td class="p-2 text-[12px] text-slate-900 text-center">{{totalStock
                items
              }}</td>
            <td></td>
            <td class="p-2 text-[12px] text-primary text-right">{{formatUSD
                (totalCostUSD items)
              }}</td>
          </tr>
        </tbody>
      </table>

      <!-- Signatures section -->
      <div class="grid grid-cols-3 gap-12 mt-8 text-center text-[11px]">
        <div class="flex flex-col items-center">
          <span class="font-semibold text-gray-700">Prepared By</span>
          <div
            class="w-28 border-b border-dashed border-gray-400 mt-8 mb-1"
          ></div>
          <span class="text-xs text-gray-400">(Signature & Date)</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="font-semibold text-gray-700">Verified By</span>
          <div
            class="w-28 border-b border-dashed border-gray-400 mt-8 mb-1"
          ></div>
          <span class="text-xs text-gray-400">(Signature & Date)</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="font-semibold text-gray-700">Approved By</span>
          <div
            class="w-28 border-b border-dashed border-gray-400 mt-8 mb-1"
          ></div>
          <span class="text-xs text-gray-400">(Signature & Date)</span>
        </div>
      </div>

      <!-- Powered By Footer -->
      <div
        class="text-center mt-8 pt-2 border-t border-gray-200 text-xs text-gray-400"
      >
        Powered by MB POS • Dynamic Inventory Intelligence Report
      </div>
    </div>
  </body>
</html>