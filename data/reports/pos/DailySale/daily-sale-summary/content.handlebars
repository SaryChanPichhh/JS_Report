<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      {{asset "data/reports/assets/report.css"}}
    </style>
  </head>
  <body>
    <div class="">
      <div class="header flex justify-between items-center">
        <img
          src="{{ShopImage}}"
          alt="shop logo"
          class="ml-8 w-28 h-28 object-contain"
        />
        <div class="flex flex-col justify-center items-center">
          <p class="text-2xl">{{ShopName}}</p>
          <p class="text-xl">Daily Sale Detail Report</p>
          <div class="flex items-center gap-1">
            <p class="text-sm">Start Date: {{formatDate StartDate}}</p>
            <span>~</span>
            <p class="text-sm">End Date: {{formatDate EndDate}}</p>
          </div>
          <div class="">
            <p class="text-sm">Printed On: {{formatDate PrintDate}}</p>
          </div>
        </div>
        <div class="mr-24"></div>
      </div>
        <div class="detail my-3">
          <table class="w-full border-collapse text-xs">
            <thead>
              <tr> <th
                  class="border-y p-1 text-center"
                  style="width: 5%;"
                >No.</th>
                <th
                  class="border-y p-1 text-center"
                  style="width: 13%;"
                >Date</th>
                <th
                  class="border-y p-1 text-center"
                  style="width: 16%;"
                >Sale</th>
                <th
                  class="border-y p-1 text-center"
                  style="width: 16%;"
                >Discount</th>
                <th class="border-y p-1 text-center" style="width: 18%;">Net
                  Price</th>
                <th
                  class="border-y p-1 text-center"
                  style="width: 16%;"
                >Cost</th>
                <th
                  class="border-y p-1 text-center"
                  style="width: 16%;"
                >Expense</th>
    
              </tr>
            </thead>
            <tbody> 
              {{#each Data}}
                <tr class="odd:bg-white even:bg-gray-100">
                  <td class="border-y p-1 text-center">{{rowNumber @index}}</td>
                  <td class="border-y p-1 text-center">{{Date}}</td>
                  <td class="border-y p-1 text-center">{{formatMoney SalePrice 'en-US' 'USD' }}</td>
                  <td class="border-y p-1 text-center">{{formatMoney Discount 'en-US' 'USD' }}</td>
                  <td class="border-y p-1 text-center">{{formatMoney (netPrice SalePrice Discount) 'en-US' 'USD' }}</td>
                  <td class="border-y p-1 text-center">{{formatMoney Cost 'en-US' 'USD' }}</td>
                  <td class="border-y p-1 text-center">{{formatMoney Expense 'en-US' 'USD' }}</td>
                </tr>
              {{/each}}
              <!-- Subtotal row for the date group -->
            </tbody>
            <tfoot>
              <tr class="font-bold bg-gray-100 border-t-2">
                <td class="border-y p-1 text-center" colspan="2">Total</td>
                <td class="border-y p-1 text-center">{{formatMoney (sumField Data "SalePrice" ) 'en-US' 'USD' }}</td>
                <td class="border-y p-1 text-center">{{formatMoney (sumField Data "Discount" ) 'en-US' 'USD' }}</td>
                <td class="border-y p-1 text-center">{{formatMoney (sumNetPrice Data) 'en-US' 'USD' }}</td>
                <td class="border-y p-1 text-center">{{formatMoney (sumField Data "Cost" ) 'en-US' 'USD' }}</td>
                <td class="border-y p-1 text-center">{{formatMoney (sumField Data "Expense" ) 'en-US' 'USD' }}</td>
              </tr>
            </tfoot>
          </table>
          
        </div>
  </body>
</html>