<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      {{asset "data/reports/assets/report.css"}}
    </style>
  </head>

  <body>
    <div class="">
      <div class="header w-full">
        <p class="text-center p-0 mb-3 text-xl">Daily Closing Inventory Detail</p>
        <div class="start-date flex items-center justify-between">
          <span class="label text-[14px]">Start Date:</span>
          <span class="value text-[14px]">{{formatDate PrintDate}}</span>
        </div>
        <div class="duration flex items-center justify-between">
          <span class="label text-[14px]">Duration:</span>
          <span class="value text-[14px]">{{Duration}}
        </div>
      </div>
      <div class="detail mt-2">
            <div class="groupby-seller ">
                {{#each (groupBySeller DailyClosings)}}
                    <div class="seller-name flex items-center justify-between leading-5 bg-primary text-white px-1 py-0.5">
                        <span class="text-[14px]">Seller :</span>
                        <span class="text-[14px]">{{Seller}}</span>
                    </div>
                    {{#each Dates}}
                        <div class="date-name text-[13px] font-medium mb-1 bg-gray-100 px-1 py-0.5">Date: {{Date}}</div>
                        <table class="w-full table-fixed border-collapse text-[9px] mt-1 mb-3">
                            <colgroup>
                                <col style="width: 35%;" />
                                <col style="width: 10%;" />
                                <col style="width: 16%;" />
                                <col style="width: 16%;" />
                                <col style="width: 16%;" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="border-y text-sm py-0.5 text-left font-normal">
                                        Name</th>
                                    <th
                                        class="border-y text-sm py-0.5 text-center font-normal"
                                    >Qty</th>
                                    <th
                                        class="border-y text-sm py-0.5 text-center font-normal"
                                    >Price</th>
                                    <th
                                        class="border-y text-sm py-0.5 text-right font-normal"
                                    >Disc.</th>
                                    <th
                                        class="border-y text-sm py-0.5 text-right font-normal"
                                    >Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each Items}}
                                    <tr>
                                        <td class="py-0.5 text-left text-[13px]">{{itemName this}}</td>
                                        <td class="py-0.5 text-center text-[13px]">{{Qty}}</td>
                                        <td class="py-0.5 text-center text-[13px]">{{formatNumber Price}}</td>
                                        <td class="py-0.5 text-right text-[13px]">{{formatNumber DiscountPrice}}</td>
                                        <td class="py-0.5 text-right text-[13px]">{{formatNumber (lineTotal this)}}</td>
                                    </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    {{/each}}
                {{/each}}
            </div>
            
            <!-- Summary Footer Section -->
            <div class="summary mt-3 text-[13px] border-t">
                <!-- Top Totals -->
                <div class="flex justify-between py-0.5">
                    <span>Total Discount</span>
                    <span>{{CurrencySymbol}}{{formatNumber (sumTotalDiscount DailyClosings)}}</span>
                </div>
                <div class="flex justify-between py-0.5">
                    <span>Sub Total</span>
                    <span>{{CurrencySymbol}}{{formatNumber SubTotal}}</span>
                </div>
                <div class="flex justify-between py-0.5">
                    <span>Discount On Invoice </span>
                    <span>{{CurrencySymbol}}{{formatNumber DiscountInvoice}}</span>
                </div>
                <div class="flex justify-between py-0.5">
                    <span>Grand Total</span>
                    <span>{{CurrencySymbol}}{{formatNumber TotalDollar}}</span>
                </div>

                <!-- Payments Section -->
                <div class="mt-3  text-center py-1 border-y border-black text-lg">Total Amount Received </div>
                {{#each (groupPayments DailyClosings)}}
                    <div class="flex justify-between py-0.5">
                        <span>{{PaymentType}}</span>
                        <span>{{@root.CurrencySymbol}}{{formatNumber TotalRecieved}}</span>
                    </div>
                {{/each}}

                <!-- Group Footers -->
                <div class="border-t"></div>
                <div class="flex justify-between py-0.5">
                    <span>Total Received</span>
                    <span>{{CurrencySymbol}}{{formatNumber (sumTotalReceived DailyClosings)}}</span>
                </div>
                <div class="flex justify-between py-0.5">
                    <span>Cash Change</span>  
                    <span>{{CurrencySymbol}}{{formatNumber CashChange}}</span>
                </div>
                <div class="flex justify-between py-0.5">
                    <span>Vat</span>
                    <span>{{CurrencySymbol}}{{formatNumber Vat}}</span>
                </div>
            </div>

            <div class="powered-by flex items-center justify-center mt-5">
              <span class="text-xs">Powered by MB POS</span>
            </div>
      </div>
    </div>
  </body>
</html>