<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      {{asset "data/reports/assets/report.css"}}
    </style>
  </head>
  <body class="bg-white text-slate-900 antialiased p-1 max-w-[80mm] [@media(min-width:140mm)]:max-w-[210mm] mx-auto">
    
    <!-- Title Header -->
    <div class="text-center py-4 border-b border-dashed border-slate-300 [@media(min-width:140mm)]:flex [@media(min-width:140mm)]:justify-center [@media(min-width:140mm)]:items-baseline [@media(min-width:140mm)]:gap-1">
      <h1 class="text-xl [@media(min-width:140mm)]:text-2xl font-bold uppercase tracking-wider text-slate-800">Daily Closing</h1>
      <h2 class="text-xs [@media(min-width:140mm)]:text-2xl  font-semibold [@media(min-width:140mm)]:font-bold [@media(min-width:140mm)]:uppercase tracking-wider text-primary [@media(min-width:140mm)]:text-slate-800 mt-0.5 [@media(min-width:140mm)]:mt-0">Inventory Report</h2>
    </div>

    <!-- Metadata Information -->
    <div class="py-3 text-xs [@media(min-width:140mm)]:text-sm border-b border-dashed border-slate-300 grid grid-cols-1 [@media(min-width:140mm)]:grid-cols-2 [@media(min-width:140mm)]:gap-x-12 gap-y-1.5">
      <div class="flex justify-between items-center">
        <span class="text-slate-500 font-medium">Seller:</span>
        <span class="text-slate-800 font-semibold">{{Seller}}</span>
      </div>
      <div class="flex justify-between items-center">
        <span class="text-slate-500 font-medium">Print Date:</span>
        <span class="text-slate-700">{{formatDate PrintDate}}</span>
      </div>
      <div class="flex justify-between items-center">
        <span class="text-slate-500 font-medium">Start Date:</span>
        <span class="text-slate-700">{{formatDate Dates}}</span>
      </div>
      <div class="flex justify-between items-center">
        <span class="text-slate-500 font-medium">Duration:</span>
        <span class="text-slate-800 font-medium">{{Duration}}</span>
      </div>
    </div>

    <!-- Items Table -->
    <div class="mt-3">
      <table class="w-full table-fixed border-collapse text-[11px] [@media(min-width:140mm)]:text-[13px]">
        <colgroup>
          <col style="width: 38%;" />
          <col style="width: 10%;" />
          <col style="width: 16%;" />
          <col style="width: 16%;" />
          <col style="width: 20%;" />
        </colgroup>
        <thead>
          <tr class="border-b border-slate-800">
            <th class="py-1.5 [@media(min-width:140mm)]:py-2.5 text-left font-bold text-slate-800 uppercase text-[9.5px] [@media(min-width:140mm)]:text-[11px]">Item</th>
            <th class="py-1.5 [@media(min-width:140mm)]:py-2.5 text-center font-bold text-slate-800 uppercase text-[9.5px] [@media(min-width:140mm)]:text-[11px]">Qty</th>
            <th class="py-1.5 [@media(min-width:140mm)]:py-2.5 text-right font-bold text-slate-800 uppercase text-[9.5px] [@media(min-width:140mm)]:text-[11px]">Price</th>
            <th class="py-1.5 [@media(min-width:140mm)]:py-2.5 text-right font-bold text-slate-800 uppercase text-[9.5px] [@media(min-width:140mm)]:text-[11px]">Disc.</th>
            <th class="py-1.5 [@media(min-width:140mm)]:py-2.5 text-right font-bold text-slate-800 uppercase text-[9.5px] [@media(min-width:140mm)]:text-[11px]">Total</th>
          </tr>
        </thead>
        <tbody>
            {{#each Items}}
              <tr class="">
                <td class="py-2 [@media(min-width:140mm)]:py-3 text-left text-slate-700 font-medium leading-tight break-words">
                  {{ItemDesc}}
                </td>
                <td class="py-2 [@media(min-width:140mm)]:py-3 text-center text-slate-600 font-medium">
                  {{Qty}}
                </td>
                <td class="py-2 [@media(min-width:140mm)]:py-3 text-right text-slate-600">
                  {{formatMoney Price "en-US" "USD"}}
                </td>
                <td class="py-2 [@media(min-width:140mm)]:py-3 text-right text-slate-500">
                  {{#if DiscountPrice}}
                    {{formatMoney DiscountPrice "en-US" "USD"}}
                  {{else}}
                    -
                  {{/if}}
                </td>
                <td class="py-2 [@media(min-width:140mm)]:py-3 text-right text-slate-800 font-semibold">
                  {{formatMoney Total "en-US" "USD"}}
                </td>
              </tr>
            {{/each}}
        </tbody>
      </table>
    </div>

    <!-- Invoice Summary -->
    <div class="mt-2 py-2.5 border-t border-slate-300 space-y-1.5 text-xs [@media(min-width:140mm)]:text-sm">
      <div class="flex justify-between items-center text-slate-600">
        <span>Total Discount</span>
        <span class="font-medium">{{formatMoney Discount "en-US" "USD"}}</span>
      </div>
      <div class="flex justify-between items-center text-slate-600">
        <span>Sub Total</span>
        <span class="font-medium">{{formatMoney SubTotal "en-US" "USD"}}</span>
      </div>
      <div class="flex justify-between items-center text-slate-600">
        <span>Discount on Invoice</span>
        <span class="font-medium">{{formatMoney Discount "en-US" "USD"}}</span>
      </div>
      <div class="flex justify-between items-center text-sm font-bold text-slate-900 pt-2 border-t border-double border-slate-400 [@media(min-width:140mm)]:text-base">
        <span>Grand Total</span>
        <span class="text-primary text-[13px] [@media(min-width:140mm)]:text-[15px] font-bold">{{formatMoney TotalDollar "en-US" "USD"}}</span>
      </div>
    </div>

    <!-- Side-by-side Layout for Received & Expenses on A4 -->
    <div class="grid grid-cols-1 [@media(min-width:140mm)]:grid-cols-2 [@media(min-width:140mm)]:gap-8">
      <!-- Received Section -->
      <div class="mt-4">
        <div class="pb-1 mb-1.5 border-b border-slate-300">
          <h3 class="text-xs [@media(min-width:140mm)]:text-sm font-bold text-slate-800 uppercase tracking-wider">Received</h3>
        </div>
        <div class="space-y-1.5 py-1 text-xs [@media(min-width:140mm)]:text-sm">
          {{#each Payments}}
            <div class="flex justify-between items-center text-slate-700">
              <span class="font-medium">{{PaymentType}}</span>
              <span class="font-semibold text-slate-800">{{formatMoney TotalReceived "en-US" "USD"}}</span>
            </div>
          {{/each}}
        </div>
      </div>

      <!-- Expenses Section -->
      <div class="mt-4">
        <div class="pb-1 mb-1.5 border-b border-slate-300">
          <h3 class="text-xs [@media(min-width:140mm)]:text-sm font-bold text-slate-800 uppercase tracking-wider">Expenses</h3>
        </div>
        <div class="space-y-1.5 py-1 text-xs [@media(min-width:140mm)]:text-sm">
          {{#each Expenses}}
            <div class="flex justify-between items-center text-slate-700">
              <span class="font-medium">{{ExpenseDesc}}</span>
              <span class="font-medium text-slate-500 text-[11px] [@media(min-width:140mm)]:text-xs">({{ExpenseBy}})</span>
              <span class="text-red-700 font-semibold">{{formatMoney ExpenseAmount "en-US" "USD"}}</span>
            </div>
          {{/each}}
        </div>
      </div>
    </div>

    <!-- Change and Tax Section -->
    <div class="mt-4 pt-2 border-t border-dashed border-slate-300 space-y-1.5 text-xs [@media(min-width:140mm)]:text-sm">
      <div class="flex justify-between items-center text-slate-600">
        <span>Cash Change</span>
        <span class="text-slate-800 font-semibold">{{formatMoney CashChange "en-US" "USD"}}</span>
      </div>
      <div class="flex justify-between items-center text-slate-600">
        <span>Tax (VAT)</span>
        <span class="text-slate-800 font-semibold">{{formatMoney Vat "en-US" "USD"}}</span>
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-8 text-center pt-4 border-t border-slate-200">
      <p class="text-[9.5px] [@media(min-width:140mm)]:text-[11px] text-slate-400 font-medium tracking-widest uppercase">Powered by MB POS</p>
    </div>

  </body>
</html>