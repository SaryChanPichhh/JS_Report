<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Daily Closing Inventory Report</title>
    <style>
      {{asset "data/reports/assets/report.css"}}
    </style>
  </head>
  <body class="bg-white text-slate-900 p-2">
    <div class="w-full">

      <!-- Header Section -->
      <div
        class="flex justify-between items-start border-b border-primary pb-2 mb-2"
      >
        <div class="flex flex-col">
          <h1 class="text-lg font-bold text-slate-900 leading-tight">DAILY
            CLOSING INVENTORY</h1>
          <p class="text-[11px] text-gray-500 mt-0.5">Valuation and Stock Sales
            Summary by Category</p>
          <div class="flex gap-4 text-[11px] mt-2 text-gray-700">
            <div>
              <span class="font-semibold text-slate-900">Seller:</span>
              <span>{{seller}}</span>
            </div>
            <div>
              <span class="font-semibold text-slate-900">Shift/Duration:</span>
              <span>{{duration}}</span>
            </div>
          </div>
        </div>

        <div class="text-right">
          <h2 class="text-xl font-bold text-primary mb-1 tracking-wider">CLOSING
            REPORT</h2>
          <div class="grid grid-cols-2 gap-1 text-[11px] text-gray-700">
            <span class="text-right font-semibold">Start Date:</span>
            <span class="text-left">{{formatDate dates}}</span>

            <span class="text-right font-semibold">Print Date:</span>
            <span class="text-left">{{formatDateTime printDate}}</span>

          </div>
        </div>
      </div>

      <!-- Details Category-Grouped Table -->
      <table class="w-full border-collapse table-fixed">
        <colgroup>
          <col style="width: 7%;" />
          <!-- Final Price -->
          <col style="width: 16%;" />
          <!-- Code -->
          <col style="width: 32%;" />
          <!-- Description -->
          <col style="width: 8%;" />
          <!-- Qty -->
          <col style="width: 11%;" />
          <!-- Unit Price -->
          <col style="width: 11%;" />
          <!-- Discount -->
          <col style="width: 15%;" />
          <!-- Line Total -->
        </colgroup>
        <thead>
          <tr class="bg-gray-100 border-b border-gray-300">
            <th
              class="text-left font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >No.</th>
            <th
              class="text-left font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Item Code</th>
            <th
              class="text-left font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Description</th>
            <th
              class="text-center font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Qty</th>
            <th
              class="text-right font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Unit Price</th>
            <th
              class="text-right font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Discount</th>
            <th
              class="text-right font-bold uppercase text-[10px] text-gray-600 p-2 tracking-wider"
            >Total (USD)</th>
          </tr>
        </thead>
        <tbody>
          {{#each (groupByCategoryCode items exchangeRate)}}
            <!-- Category Header Row -->
            <tr class="bg-primary text-white border-b border-primary">
              <td
                colspan="2"
                class="p-1.5 font-bold text-[10px] uppercase tracking-wider"
              >
                Category:
                {{categoryDesc}}
                ({{categoryCode}})
              </td>
              <td colspan="4" class="p-1.5 text-right"></td>
              <td class="p-1.5 text-right font-bold text-[10px]">{{formatUSD
                  subTotalUSD
                }}</td>
            </tr>

            <!-- Category Items Row -->
            {{#each items}}
              <tr class="border-b border-gray-200 even:bg-gray-50">
                <td
                  class="p-1.5 text-[11px] font-mono text-gray-600"
                >{{rowNumber @index}}</td><td
                  class="p-1.5 text-[11px] font-mono text-gray-600"
                >{{itemCode}}</td>
                <td
                  class="p-1.5 text-[11px] font-medium text-slate-900"
                >{{itemDesc}}</td>
                <td
                  class="p-1.5 text-[11px] text-center text-slate-900"
                >{{qty}}</td>
                <td
                  class="p-1.5 text-[11px] text-right text-slate-900"
                >{{formatUSD price}}</td>
                <td
                  class="p-1.5 text-[11px] text-right text-red-600"
                >{{formatUSD discountPrice}}</td>

                <td
                  class="p-1.5 text-[11px] text-right font-semibold text-slate-900"
                >{{formatUSD total}}</td>
              </tr>
            {{/each}}
          {{/each}}

          <!-- Grand Total Row -->
          <tr class="bg-gray-100 border-t border-primary font-bold">
            <td
              colspan="3"
              class="p-1.5 text-[12px] text-slate-900 text-left"
            >SubTotal</td>
            <td class="p-1.5 text-[12px] text-slate-900 text-center">{{totalQty
                items
              }}</td>
            <td colspan="2" class="p-1.5 text-right"></td>
            <td class="p-1.5 text-[12px] text-primary text-right">{{formatUSD
                (totalItemCostUSD items)
              }}</td>
          </tr>
        </tbody>
      </table>

      <!-- Landscape Detailed Side-By-Side Footer Section -->
      <div class="grid grid-cols-3 gap-4 mt-3">

        <!-- Payment Breakdown Card -->
        <div
          class="bg-gray-50 border border-gray-200 rounded-lg p-3 flex flex-col"
        >
          <span
            class="border-b border-gray-300 pb-1 mb-2 text-[11px] font-bold text-primary uppercase tracking-wider"
          >Payment Methods</span>
          <div class="flex flex-col">
            {{#each payments}}
              <div
                class="flex justify-between items-center py-1 text-[11px] border-b border-gray-100 last:border-0"
              >
                <span class="text-slate-900 font-medium">{{paymentType}}</span>
                <span class="font-bold text-slate-900">{{formatUSD
                    totalRecieved
                  }}</span>
              </div>
            {{/each}}
          </div>
        </div>

        <!-- Expenses Listing Card -->
        <div
          class="bg-gray-50 border border-gray-200 rounded-lg p-3 flex flex-col"
        >
          <span
            class="border-b border-gray-300 pb-1 mb-2 text-[11px] font-bold text-primary uppercase tracking-wider"
          >Expenses</span>
          <div class="flex flex-col">
            {{#each expenses}}
              <div
                class="flex justify-between items-start py-1 text-[11px] border-b border-gray-100 last:border-0"
              >
                <div class="flex flex-col">
                  <span
                    class="text-slate-900 font-medium"
                  >{{expenseDesc}}</span>
                  <span class="text-[9px] text-gray-400 font-normal">by
                    {{expenseBy}}</span>
                </div>
                <span class="font-bold text-red-600">{{formatUSD
                    expenseAmount
                  }}</span>
              </div>
            {{/each}}
          </div>
        </div>

        <!-- Financial Summary Card -->
        <div
          class="bg-gray-50 border border-gray-200 rounded-lg p-3 flex flex-col justify-between"
        >
          <span
            class="border-b border-gray-300 pb-1 mb-2 text-[11px] font-bold text-primary uppercase tracking-wider"
          >Summary</span>
          <div class="flex flex-col">
            <div class="flex justify-between items-center py-0.5 text-[11px]">
              <span class="text-gray-600">SubTotal</span>
              <span class="font-medium text-slate-900">{{formatUSD
                  subTotal
                }}</span>
            </div>
            <div
              class="flex justify-between items-center py-0.5 text-[11px] text-red-600"
            >
              <span>Invoice Discounts</span>
              <span>{{formatUSD discount}}</span>
            </div>
            <div class="flex justify-between items-center py-0.5 text-[11px]">
              <span class="text-gray-600">VAT / Tax</span>
              <span class="font-medium text-slate-900">{{formatUSD vat}}</span>
            </div>

            <div class="flex justify-between items-center py-0.5 text-[11px]">
              <span class="text-gray-600">Cash Change Given</span>
              <span class="font-medium text-slate-900">{{formatUSD
                  cashChange
                }}</span>
            </div>
            <div class="border-t border-gray-300 my-1.5"></div>
            <div
              class="flex justify-between items-center py-0.5 text-xs font-bold text-primary"
            >
              <span>Grand Total</span>
              <span>{{formatUSD totalDollar}}</span>
            </div>

          </div>
        </div>

      </div>

      <!-- Signatures section -->
      {{! <div class="grid grid-cols-3 gap-12 mt-8 text-center text-[11px]">
        <div class="flex flex-col items-center">
          <span class="font-semibold text-gray-700">Prepared By</span>
          <div
            class="w-28 border-b border-dashed border-gray-400 mt-8 mb-1"
          ></div>
          <span class="text-xs text-gray-400">(Signature & Date)</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="font-semibold text-gray-700">Verified By</span>
          <div
            class="w-28 border-b border-dashed border-gray-400 mt-8 mb-1"
          ></div>
          <span class="text-xs text-gray-400">(Signature & Date)</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="font-semibold text-gray-700">Approved By</span>
          <div
            class="w-28 border-b border-dashed border-gray-400 mt-8 mb-1"
          ></div>
          <span class="text-xs text-gray-400">(Signature & Date)</span>
        </div>
      </div> }}

      <!-- Powered By Footer -->
      <div
        class="text-center mt-6 pt-2 border-t border-gray-200 text-xs text-gray-400"
      >
        Powered by MB POS
      </div>
    </div>
  </body>
</html>